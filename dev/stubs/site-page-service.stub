/**
 * {{class_name}} site sayfasi icin view verisini hazirlar.
 */
final class {{class_name}}PageService extends BasePageService
{
    /**
     * Sayfa verisini dondurur.
     *
     * @param string $path Mevcut istek yolu.
     * @return ServiceResult
