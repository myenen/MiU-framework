 */
final class {{class_name}} extends ApiController
{
    /**
     * @param View $view Controller bagimlilik tutarliligi icin eklenen view.
     * @param {{class_name}}Service $service API servis katmani.
     */
    public function __construct(
        View $view,
        private readonly {{class_name}}Service $service
    ) {
        parent::__construct($view);
